<Application x:Class="WSharp.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnMainWindowClose">
    
    <Application.Resources>
       
        <SolidColorBrush x:Key="BackgroundBrush"   Color="#1E1E1E" />
        <SolidColorBrush x:Key="SideBarBrush"      Color="#252526" />
        <SolidColorBrush x:Key="BorderBrush"       Color="#2D2D30" />
        <SolidColorBrush x:Key="AccentBrush"       Color="#007ACC" />
        <SolidColorBrush x:Key="TextBrush"         Color="#DCDCDC" />
        <SolidColorBrush x:Key="ErrorBrush"        Color="#FF6464" />
    </Application.Resources>
</Application>
