<Window x:Class="WSharp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit"
        xmlns:scottplot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        Title="WSharp Studio — Scientific Edition"
        Height="900" Width="1600"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E" Foreground="#DCDCDC"
        WindowState="Maximized">

    <Window.Resources>
        
        <Style x:Key="DarkButton" TargetType="Button">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="#DCDCDC"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3E3E42"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#007ACC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        
        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource DarkButton}">
            <Setter Property="Background" Value="#0E639C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

     
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#6B6B6B"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Background" Value="#252526"/>
        </Style>

        
        <Style TargetType="TreeView">
            <Setter Property="Background" Value="#252526"/>
            <Setter Property="Foreground" Value="#DCDCDC"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style TargetType="TreeViewItem">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="2"/>
        </Style>

      
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="#969696"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="tabBorder"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                BorderThickness="0,0,0,2"
                                BorderBrush="Transparent">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="tabBorder" Property="Background" Value="#1E1E1E"/>
                                <Setter TargetName="tabBorder" Property="BorderBrush" Value="#007ACC"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="tabBorder" Property="Background" Value="#2D2D30"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>    
            <RowDefinition Height="*"/>       
            <RowDefinition Height="24"/>     
        </Grid.RowDefinitions>

      
        <Border Grid.Row="0" Background="#252526" BorderBrush="#3F3F46" BorderThickness="0,0,0,1" Padding="8,4">
            <DockPanel>
               
                <TextBlock DockPanel.Dock="Left"
                           Text="W#" FontFamily="Consolas" FontSize="18" FontWeight="Bold"
                           Foreground="#007ACC" VerticalAlignment="Center" Margin="0,0,16,0"/>

                <TextBlock DockPanel.Dock="Left" Text="Lingua Medica"
                           FontFamily="Segoe UI" FontSize="12" Foreground="#6B6B6B"
                           VerticalAlignment="Center" Margin="0,0,24,0"/>

                
                <Button DockPanel.Dock="Left" Content="📄 New"
                        Style="{StaticResource DarkButton}" Click="NewFile_Click" Margin="0,0,4,0"/>
                <Button DockPanel.Dock="Left" Content="💾 Save"
                        Style="{StaticResource DarkButton}" Click="SaveFile_Click" Margin="0,0,4,0"/>
                <Button DockPanel.Dock="Left" Content="📁 Open"
                        Style="{StaticResource DarkButton}" Click="OpenFile_Click" Margin="0,0,16,0"/>

                
                <Button x:Name="RunButton" DockPanel.Dock="Right"
                        Content="▶  RUN  (F5)"
                        Style="{StaticResource AccentButton}"
                        Click="RunButton_Click" Margin="0,0,0,0"/>

                
                <TextBlock/>
            </DockPanel>
        </Border>

        
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="150"/>   
                <ColumnDefinition Width="Auto"/>                  
                <ColumnDefinition Width="*" MinWidth="300"/>      
                <ColumnDefinition Width="Auto"/>                  
                <ColumnDefinition Width="300" MinWidth="200"/>    
            </Grid.ColumnDefinitions>

            
            <Grid Grid.Column="0" Background="#252526">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="5"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

               
                <TextBlock Grid.Row="0" Text="  EXPLORER" Style="{StaticResource SectionHeader}"/>

               
                <TreeView x:Name="FileExplorer" Grid.Row="1"
                          MouseDoubleClick="FileExplorer_DoubleClick"/>

                
                <GridSplitter Grid.Row="3" Height="5" HorizontalAlignment="Stretch"
                              Background="#3F3F46" ResizeBehavior="PreviousAndNext"/>

                
                <TextBlock Grid.Row="4" Text="  MEMORY WATCH" Style="{StaticResource SectionHeader}"/>

                
                <TreeView x:Name="VariableWatcher" Grid.Row="5">
                    <TreeViewItem Header="📀 Memory Empty" Foreground="#6B6B6B"/>
                </TreeView>
            </Grid>

            
            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center"
                          VerticalAlignment="Stretch" Background="#3F3F46"/>

            
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="3*" MinHeight="200"/> 
                    <RowDefinition Height="Auto"/>                 
                    <RowDefinition Height="*" MinHeight="120"/>  
                </Grid.RowDefinitions>

               
                <Border Grid.Row="0" Background="#1E1E1E" BorderBrush="#3F3F46" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                       
                        <Border Grid.Row="0" Background="#252526" Padding="4,2">
                            <StackPanel x:Name="EditorTabBar" Orientation="Horizontal">
                                <TextBlock Text="  untitled.we" Foreground="White" FontSize="11"
                                           FontFamily="Segoe UI" VerticalAlignment="Center"
                                           Padding="8,4" Background="#1E1E1E"/>
                            </StackPanel>
                        </Border>

                      
                        <avalonedit:TextEditor
                            x:Name="CodeEditor" Grid.Row="1"
                            FontFamily="Consolas" FontSize="14"
                            Background="#1E1E1E" Foreground="#DCDCDC"
                            ShowLineNumbers="True"
                            HorizontalScrollBarVisibility="Auto"
                            VerticalScrollBarVisibility="Auto"
                            LineNumbersForeground="#4B5263"
                            Padding="4"/>
                    </Grid>
                </Border>

               
                <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch"
                              Background="#3F3F46" ResizeBehavior="PreviousAndNext"/>

                
                <TabControl x:Name="OutputTabs" Grid.Row="2">
                
                    <TabItem Header="⌨ Terminal">
                        <TextBox x:Name="ConsoleOutput"
                                 IsReadOnly="True"
                                 Background="#0C0C0C" Foreground="#CCCCCC"
                                 FontFamily="Consolas" FontSize="11"
                                 BorderThickness="0"
                                 TextWrapping="NoWrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 Padding="8,4"/>
                    </TabItem>

                    
                    <TabItem Header="🔍 Diagnostics">
                        <TextBox x:Name="ErrorLog"
                                 IsReadOnly="True"
                                 Background="#19141A" Foreground="#FF6464"
                                 FontFamily="Consolas" FontSize="11"
                                 BorderThickness="0"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 Padding="8,4"
                                 Text="No issues found."/>
                    </TabItem>
                </TabControl>
            </Grid>

       
            <GridSplitter Grid.Column="3" Width="4" HorizontalAlignment="Center"
                          VerticalAlignment="Stretch" Background="#3F3F46"/>

           
            <Grid Grid.Column="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="2*" MinHeight="150"/> 
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="5"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*" MinHeight="100"/>  
                </Grid.RowDefinitions>

              
                <TextBlock Grid.Row="0" Text="  SCIENTIFIC PLOTTER" Style="{StaticResource SectionHeader}"/>

                
                <scottplot:WpfPlot x:Name="MainPlot" Grid.Row="1"/>

              
                <GridSplitter Grid.Row="3" Height="5" HorizontalAlignment="Stretch"
                              Background="#3F3F46" ResizeBehavior="PreviousAndNext"/>

              
                <TextBlock Grid.Row="4" Text="  AI ASSISTANT" Style="{StaticResource SectionHeader}"/>

              
                <TextBox x:Name="AiInput" Grid.Row="5"
                         Background="#252526" Foreground="#DCDCDC"
                         FontFamily="Segoe UI" FontSize="12"
                         BorderThickness="0"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         Padding="8,4"
                         Text="// AI Assistant Ready..."/>
            </Grid>
        </Grid>

       
        <Border Grid.Row="2" Background="#007ACC" Padding="8,2">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left" Text="WSharp Engine Active"
                           Foreground="White" FontSize="11" FontFamily="Segoe UI"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="StatusText" DockPanel.Dock="Right"
                           Text="Ready" Foreground="White" FontSize="11"
                           FontFamily="Segoe UI" VerticalAlignment="Center"
                           HorizontalAlignment="Right"/>
            </DockPanel>
        </Border>
    </Grid>

    
    <Window.InputBindings>
        <KeyBinding Key="F5" Command="{x:Static ApplicationCommands.NotACommand}"
                    x:Name="F5Binding"/>
        <KeyBinding Key="S" Modifiers="Control" Command="{x:Static ApplicationCommands.NotACommand}"
                    x:Name="CtrlSBinding"/>
        <KeyBinding Key="N" Modifiers="Control" Command="{x:Static ApplicationCommands.NotACommand}"
                    x:Name="CtrlNBinding"/>
    </Window.InputBindings>
</Window>
