print "File: test_04_scope_closure.we"
let x = 100
func outer() {
    let y = 200
    func inner() {
        let z = 300
        return x + y + z
    }
    return inner()
}
let result = outer()
if result == 600 { print "PASS: nested scope sum" } else { print "FAIL: nested scope sum" }
func make_adder(n) {
    func adder(v) {
        return v + n
    }
    return adder
}
let add5 = make_adder(5)
let r2 = add5(10)
if r2 == 15 { print "PASS: closure adder" } else { print "FAIL: closure adder" }
let add10 = make_adder(10)
let r3 = add10(10)
if r3 == 20 { print "PASS: closure adder 2" } else { print "FAIL: closure adder 2" }
let counter = 0
func inc() { counter = counter + 1 }
inc()
inc()
inc()
if counter == 3 { print "PASS: global mutation" } else { print "FAIL: global mutation" }
func shadow_test() {
    let x = 999
    return x
}
let sr = shadow_test()
if sr == 999 { print "PASS: local shadow" } else { print "FAIL: local shadow" }
if x == 100 { print "PASS: global unchanged" } else { print "FAIL: global unchanged" }
print "test_04 done"
