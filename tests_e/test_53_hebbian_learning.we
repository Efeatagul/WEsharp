print "File: test_53_hebbian_learning.we"
let w = 0.5
let lr = 0.01
let pre_rate = 50.0
let post_rate = 60.0

let dw = lr * pre_rate * post_rate
w = w + dw

if w > 0.5 + 29.9 && w < 0.5 + 30.1 { print "PASS: Oja Hebbian weight update" } else { print "FAIL: Oja Hebbian weight update" }

let oja_alpha = 0.001
let oja_dw = lr * pre_rate * post_rate - oja_alpha * post_rate * post_rate * w
w = w + oja_dw

if w < 30.5 + 30 - 1.0 { print "PASS: Oja decay normalization" } else { print "FAIL: Oja decay normalization" }

print "test_53 done"
