print "File: test_44_stdp_trace.we"
let w = 0.5
let max_w = 1.0
let pre_trace = 0.0
let post_trace = 0.0
let tau_pre = 20.0
let tau_post = 20.0
let a_plus = 0.1
let a_minus = -0.1

func apply_stdp(delta_t) {
    if delta_t > 0 {
        pre_trace = math_basic("pow", 2.718, -delta_t / tau_pre)
        w = w + a_plus * pre_trace    
    } else {
        post_trace = math_basic("pow", 2.718, delta_t / tau_post)
        w = w + a_minus * post_trace
    }
    if w > max_w { w = max_w }
    if w < 0.0 { w = 0.0 }
    return w
}

apply_stdp(10)
if w > 0.55 && w < 0.57 { print "PASS: STDP potentiation dt=10" } else { print "FAIL: STDP potentiation dt=10" }

apply_stdp(-10)
if w > 0.49 && w < 0.51 { print "PASS: STDP depression dt=-10" } else { print "FAIL: STDP depression dt=-10" }

print "test_44 done"
