print "File: test_34_stats_median_mode.we"
func median(arr) {
    let sorted = sort(arr)
    let n = len(sorted)
    if n % 2 == 1 { return sorted[floor(n / 2)] }
    return (sorted[floor(n / 2) - 1] + sorted[floor(n / 2)]) / 2.0
}
func mode(arr) {
    let counts = {}
    foreach item in arr {
        let key = to_string(item)
        if is_key counts key { counts[key] = counts[key] + 1 }
        else { counts[key] = 1 }
    }
    let max_count = 0
    let mode_val = arr[0]
    foreach k in counts {
        if counts[k] > max_count {
            max_count = counts[k]
            mode_val = to_number(k)
        }
    }
    return mode_val
}

let d1 = [1, 3, 3, 6, 7, 8, 9]
let med1 = median(d1)
if med1 == 6 { print "PASS: median odd len" } else { print "FAIL: median odd len" }

let d2 = [1, 2, 3, 4, 5, 6, 8, 9]
let med2 = median(d2)
if med2 == 4.5 { print "PASS: median even len" } else { print "FAIL: median even len" }

let d3 = [1, 2, 2, 3, 3, 3, 4, 5]
let mod3 = mode(d3)
if mod3 == 3 { print "PASS: mode" } else { print "FAIL: mode" }

print "test_34 done"
