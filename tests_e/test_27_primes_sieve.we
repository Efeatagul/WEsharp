print "File: test_27_primes_sieve.we"
func sieve(limit) {
    let is_prime = []
    let i = 0
    while i <= limit {
        push(is_prime, true)
        i = i + 1
    }
    is_prime[0] = false
    is_prime[1] = false
    let p = 2
    while p * p <= limit {
        if is_prime[p] == true {
            let m = p * p
            while m <= limit {
                is_prime[m] = false
                m = m + p
            }
        }
        p = p + 1
    }
    let primes = []
    let j = 2
    while j <= limit {
        if is_prime[j] == true { push(primes, j) }
        j = j + 1
    }
    return primes
}
let primes = sieve(50)
if primes[0] == 2 { print "PASS: first prime" } else { print "FAIL: first prime" }
if primes[1] == 3 { print "PASS: second prime" } else { print "FAIL: second prime" }
if primes[2] == 5 { print "PASS: third prime" } else { print "FAIL: third prime" }
if len(primes) == 15 { print "PASS: primes count up to 50" } else { print "FAIL: primes count up to 50" }
if primes[14] == 47 { print "PASS: last prime<=50 is 47" } else { print "FAIL: last prime<=50 is 47" }
print "test_27 done"
