print "File: test_89_stress_mixed_math_logic.we"
let a = 1
let b = 1
let c = 1
let count = 0

while a < 20 {
    b = 1
    while b < 20 {
        c = 1
        while c < 20 {
            if (a * a + b * b == c * c) || (b * b + c * c == a * a) || (c * c + a * a == b * b) {
                count = count + 1
            }
            c = c + 1
        }
        b = b + 1
    }
    a = a + 1
}

if count > 0 { print "PASS: Pythagorean triples found in loop" } else { print "FAIL: Pythagorean triples found in loop" }

print "test_89 done"
