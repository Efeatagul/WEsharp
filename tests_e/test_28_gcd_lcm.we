print "File: test_28_gcd_lcm.we"
func gcd(a, b) {
    while b != 0 {
        let t = b
        b = a % b
        a = t
    }
    return a
}
func lcm(a, b) {
    return (a * b) / gcd(a, b)
}
let g1 = gcd(48, 18)
if g1 == 6 { print "PASS: gcd(48,18)=6" } else { print "FAIL: gcd(48,18)=6" }
let g2 = gcd(100, 75)
if g2 == 25 { print "PASS: gcd(100,75)=25" } else { print "FAIL: gcd(100,75)=25" }
let g3 = gcd(17, 13)
if g3 == 1 { print "PASS: gcd coprime=1" } else { print "FAIL: gcd coprime=1" }
let g4 = gcd(0, 5)
if g4 == 5 { print "PASS: gcd(0,5)=5" } else { print "FAIL: gcd(0,5)=5" }
let l1 = lcm(4, 6)
if l1 == 12 { print "PASS: lcm(4,6)=12" } else { print "FAIL: lcm(4,6)=12" }
let l2 = lcm(12, 18)
if l2 == 36 { print "PASS: lcm(12,18)=36" } else { print "FAIL: lcm(12,18)=36" }
let l3 = lcm(7, 11)
if l3 == 77 { print "PASS: lcm(7,11)=77" } else { print "FAIL: lcm(7,11)=77" }
print "test_28 done"
