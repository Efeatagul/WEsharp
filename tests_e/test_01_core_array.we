print "File: test_01_core_array.we"
let arr = [10, 20, 30, 40, 50]
let first = arr[0]
let last = arr[4]
let sum = first + last
if sum == 60 { print "PASS: first+last" } else { print "FAIL: first+last" }
push(arr, 60)
let n = len(arr)
if n == 6 { print "PASS: push len" } else { print "FAIL: push len" }
let popped = pop(arr)
if popped == 60 { print "PASS: pop value" } else { print "FAIL: pop value" }
let slice = arr[1:3]
if len(slice) == 2 { print "PASS: slice len" } else { print "FAIL: slice len" }
if slice[0] == 20 { print "PASS: slice[0]" } else { print "FAIL: slice[0]" }
let nested = [[1, 2], [3, 4], [5, 6]]
let inner = nested[1]
if inner[0] == 3 { print "PASS: nested array" } else { print "FAIL: nested array" }
let total = 0
foreach item in arr { total = total + item }
if total == 150 { print "PASS: foreach sum" } else { print "FAIL: foreach sum" }
print "test_01 done"
