print "File: test_13_statistics.we"
let data = [4, 7, 13, 2, 1, 8, 11, 3, 5, 6]
let a = avg(data)
if a == 6 { print "PASS: avg" } else { print "FAIL: avg" }
let mx = max(data)
if mx == 13 { print "PASS: max" } else { print "FAIL: max" }
let mn = min(data)
if mn == 1 { print "PASS: min" } else { print "FAIL: min" }
let sd = std_dev(data)
if sd > 3.4 { print "PASS: std_dev > 3.4" } else { print "FAIL: std_dev > 3.4" }
if sd < 3.6 { print "PASS: std_dev < 3.6" } else { print "FAIL: std_dev < 3.6" }
let sorted_data = sort(data)
let median = sorted_data[4]
if median == 5 { print "PASS: median (lower mid)" } else { print "FAIL: median (lower mid)" }
let uniform = [5, 5, 5, 5, 5]
let ua = avg(uniform)
if ua == 5 { print "PASS: avg uniform" } else { print "FAIL: avg uniform" }
let usd = std_dev(uniform)
if usd == 0 { print "PASS: std_dev uniform" } else { print "FAIL: std_dev uniform" }
let neg = [-3, -1, 0, 1, 3]
let na = avg(neg)
if na == 0 { print "PASS: avg neg+pos" } else { print "FAIL: avg neg+pos" }
print "test_13 done"
