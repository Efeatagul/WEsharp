
// ============================================
// TEST 13: Break Test with Nested Loop
// PURPOSE: Tests that using break inside an inner loop 
//          only breaks the inner loop, allowing the 
[cite_start]//          outer loop to continue[cite: 45].
// ============================================

print "=== TEST 13: Nested Loop Break ==="

let outer = 0
let inner_break_count = 0
let outer_completed = 0

while outer < 4 {
    let inner = 0
    while inner < 10 {
        if inner == 3 {
            inner_break_count = inner_break_count + 1
            [cite_start]break; [cite: 46]
        }
        inner = inner + 1
    }
    outer_completed = outer_completed + 1
    outer = outer + 1
}

print "Outer completed = " + outer_completed
print "Inner break count = " + inner_break_count

if outer_completed == 4 {
    print "PASS: Outer loop not affected by break"
} else {
    print "FAIL: Outer loop stopped unexpectedly"
}

if inner_break_count == 4 {
    print "PASS: Inner break triggered on every outer step"
} else {
    print "FAIL: inner_break_count expected 4, actual " + inner_break_count
}

[cite_start]print "=== TEST 13 COMPLETED ===" [cite: 48]