// ============================================
// TEST 17: Foreach Nested Foreach Loop
// PURPOSE: Tests the operation of nested foreach loops 
//          on two different lists to ensure all combinations 
[cite_start]//          are generated correctly[cite: 59].
// ============================================

print "=== TEST 17: Foreach Nested Foreach ==="

let colors = ["red", "green", "blue"]
let sizes = ["small", "medium", "large"]
let combinations = 0

foreach (color in colors) {
    foreach (size in sizes) {
        print color + " - " + size
        combinations = combinations + 1
    }
}

print "Total combinations = " + combinations

if combinations == 9 {
    print "PASS: 3x3 = 9 combinations correct"
} else {
    print "FAIL: Expected 9, actual " + combinations
}

[cite_start]print "=== TEST 17 COMPLETED ===" [cite: 61]