// ============================================
// TEST 11: Basic Nested While Loop
// PURPOSE: To verify that a simple two-layer nested while loop 
//          functions correctly. The inner loop must restart 
//          on every outer step.
// ============================================

print "=== TEST 11: Basic Nested While ==="

let outer = 1
let total = 0

while outer <= 3 {
    let inner = 1
    while inner <= 3 {
        total = total + 1
        print "outer=" + outer + " inner=" + inner
        inner = inner + 1
    }
    outer = outer + 1
}

print "Total iterations = " + total

if total == 9 {
    print "PASS: 3x3 = 9 iterations correct"
} else {
    print "FAIL: Expected 9, actual " + total
}

print "=== TEST 11 COMPLETED ==="