// ============================================
// TEST 19: Nested Loop Early Exit (Double Break)
// PURPOSE: Breaking out of the entire operation using a break in 
[cite_start]//          the outer loop based on a flag set in the inner loop[cite: 65, 66].
// ============================================

print "=== TEST 19: Nested Loop Early Exit ==="

let target = 42
let found = false
let found_i = -1
let found_j = -1

let i = 1
while i <= 10 {
    let j = 1
    while j <= 10 {
        let product = i * j
        if product == target {
            found_i = i
            found_j = j
            [cite_start]found = true [cite: 68]
            break;
        }
        j = j + 1
    }
    if found == true {
        [cite_start]break; [cite: 70]
    }
    i = i + 1
}

print "Target: " + target

if found == true {
    print "Found: " + found_i + " x " + found_j + " = " + target
    print "PASS: Flag-based double break worked"
} else {
    print "FAIL: Target not found"
}

print "=== TEST 19 COMPLETED ==="