// ============================================
// TEST 08: Modifying Outer Variable from Inner Block
// PURPOSE: Inner block should be able to modify variables 
//          in the upper scope (without redeclaring with 'let').
//          This is NOT a scope leak, it is normal assignment[cite: 1, 2].
// ============================================

print "=== TEST 08: Modifying Outer Variable from Inner Block ==="

let counter = 0
print "Initial counter = " + counter

if true {
    counter = 10
    print "Inside if, counter = " + counter [cite: 3]
}

print "After if, counter = " + counter

if counter == 10 {
    print "PASS: Inner block successfully modified the outer variable" [cite: 3]
} else {
    print "FAIL: Assignment did not work, counter = " + counter [cite: 3]
}

// Modifying outer variable inside a while loop
let savings = 0
let i = 1
while i <= 5 {
    savings = savings + i
    i = i + 1 [cite: 4]
}

print "savings = " + savings

if savings == 15 {
    print "PASS: Outer variable updated correctly from while loop" [cite: 4]
} else {
    print "FAIL: savings is incorrect, expected 15 actual " + savings [cite: 4]
}

print "=== TEST 08 COMPLETED ==="

