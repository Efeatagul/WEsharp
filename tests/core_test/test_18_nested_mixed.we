// ============================================
// TEST 18: Foreach Inside While Mixed Loop
// PURPOSE: Verifies that while and foreach loops do 
[cite_start]//          not conflict when used together in a nested structure[cite: 62].
// ============================================

print "=== TEST 18: While + Foreach Mixed ==="

let rounds = ["alpha", "beta", "gamma"]
let round_counter = 0
let total_operations = 0

while round_counter < 3 {
    print "--- Round " + round_counter + " ---"
    foreach (label in rounds) {
        print "  round=" + round_counter + " label=" + label
        total_operations = total_operations + 1
    }
    round_counter = round_counter + 1
}

print "Total operations = " + total_operations

if total_operations == 9 {
    [cite_start]print "PASS: 3 rounds x 3 labels = 9 operations" [cite: 64]
} else {
    print "FAIL: Expected 9, actual " + total_operations
}

print "=== TEST 18 COMPLETED ==="
