// ============================================
// TEST 10: Recursive Function Scope Isolation
// PURPOSE: To verify that each call in recursive function calls 
//          has its own scope and does not overwrite the 
//          local variables of the calls above it[cite: 9].
// ============================================

print "=== TEST 10: Recursive Function Scope ==="

func factorial(n) {
    let level = n
    if n <= 1 {
        print "  Base: level=" + level + " n=" + n [cite: 10]
        return 1
    }
    let sub = factorial(n - 1)
    print "  Return: level=" + level + " n=" + n + " sub=" + sub [cite: 10]
    return n * sub
}

let result = factorial(5)
print "5! = " + result [cite: 10, 11]

if result == 120 {
    print "PASS: Recursive scope isolation successful" [cite: 11]
} else {
    print "FAIL: Incorrect result, expected 120 actual " + result [cite: 11]
}

// n and level should be inaccessible in global
try {
    print "n = " + n
    print "FAIL: recursive n leaked to global!" [cite: 11, 12]
} catch {
    print "PASS: recursive parameter 'n' is isolated" [cite: 12]
}

print "=== TEST 10 COMPLETED ==="

