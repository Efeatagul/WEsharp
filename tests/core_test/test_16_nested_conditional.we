// ============================================
// TEST 16: Condition Filter Inside Nested Loop
// PURPOSE: Verifies the correct operation of a scenario 
//          that filters specific values using an if condition 
[cite_start]//          inside an inner loop[cite: 56].
// ============================================

print "=== TEST 16: Nested Loop Condition Filter ==="

let found = 0
let i = 1

while i <= 10 {
    let j = 1
    while j <= 10 {
        // Count only products between 20 and 30
        let product = i * j
        if product > 20 && product < 30 {
            [cite_start]print "Found: " + i + " x " + j + " = " + product [cite: 57, 58]
            found = found + 1
        }
        j = j + 1
    }
    i = i + 1
}

print "Found pair count = " + found

if found > 0 {
    print "PASS: Filter worked, " + found + " pairs found"
} else {
    print "FAIL: No pairs found"
}

print "=== TEST 16 COMPLETED ==="